      "difficulty": 2,
      "source": "Sample (CBSE 10)",
      "prompt": {
        "en": "The roots of the quadratic equation x² − 5x + 6 = 0 are:"
      },
      "choices": [
        {
          "en": "2 and 3"
        },
        {
          "en": "1 and 6"
        },
        {
          "en": "−2 and −3"
