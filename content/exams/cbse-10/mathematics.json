{
  "exam": "cbse-10", "subject": "mathematics", "draft": true,
  "note": "SAMPLE CBSE Class 10 board-pattern questions (source 'Sample (CBSE 10)'). Replace with verified board PYQs + SME solutions + 13-language translations before shipping.",
  "questions": [
    { "id": "cbse-10-mathematics-sample-001", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "real-numbers", "difficulty": 2, "source": "Sample (CBSE 10)",
      "prompt": { "en": "For two positive integers, HCF × LCM equals:" },
      "choices": [ { "en": "The sum of the two numbers" }, { "en": "The product of the two numbers" }, { "en": "The larger number" }, { "en": "The difference of the numbers" } ], "answerIndex": 1,
      "solution": { "en": "For any two positive integers a and b, HCF(a,b) × LCM(a,b) = a × b." } },
    { "id": "cbse-10-mathematics-sample-002", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "quadratic-equations", "difficulty": 2, "source": "Sample (CBSE 10)",
      "prompt": { "en": "The roots of the quadratic equation x² − 5x + 6 = 0 are:" },
      "choices": [ { "en": "2 and 3" }, { "en": "1 and 6" }, { "en": "−2 and −3" }, { "en": "5 and 6" } ], "answerIndex": 0,
      "solution": { "en": "x² − 5x + 6 = (x−2)(x−3) = 0, so x = 2 or x = 3. They add to 5 and multiply to 6, matching the equation." } },
    { "id": "cbse-10-mathematics-sample-003", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "coordinate-geometry", "difficulty": 2, "source": "Sample (CBSE 10)",
      "prompt": { "en": "The distance between the points (0, 0) and (3, 4) is:" },
      "choices": [ { "en": "5" }, { "en": "7" }, { "en": "12" }, { "en": "25" } ], "answerIndex": 0,
      "solution": { "en": "Distance = √((3−0)² + (4−0)²) = √(9 + 16) = √25 = 5." } },
    { "id": "cbse-10-mathematics-sample-004", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "trigonometry", "difficulty": 1, "source": "Sample (CBSE 10)",
      "prompt": { "en": "The value of sin 30° is:" },
      "choices": [ { "en": "1" }, { "en": "1/2" }, { "en": "√3/2" }, { "en": "0" } ], "answerIndex": 1,
      "solution": { "en": "sin 30° = 1/2. (cos 30° = √3/2 and tan 30° = 1/√3.)" } },
    { "id": "cbse-10-mathematics-sample-005", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "arithmetic-progressions", "difficulty": 2, "source": "Sample (CBSE 10)",
      "prompt": { "en": "In an AP with first term a and common difference d, the nth term is:" },
      "choices": [ { "en": "a + nd" }, { "en": "a + (n − 1)d" }, { "en": "a − (n − 1)d" }, { "en": "na + d" } ], "answerIndex": 1,
      "solution": { "en": "The nth term of an arithmetic progression is aₙ = a + (n − 1)d." } },
    { "id": "cbse-10-mathematics-sample-006", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "probability", "difficulty": 1, "source": "Sample (CBSE 10)",
      "prompt": { "en": "The probability of getting a head when a fair coin is tossed once is:" },
      "choices": [ { "en": "1" }, { "en": "0" }, { "en": "1/2" }, { "en": "2" } ], "answerIndex": 2,
      "solution": { "en": "There are 2 equally likely outcomes (head, tail), so P(head) = 1/2." } },
    { "id": "cbse-10-mathematics-sample-007", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "circles", "difficulty": 2, "source": "Sample (CBSE 10)",
      "prompt": { "en": "The area of a circle of radius 7 cm (take π = 22/7) is:" },
      "choices": [ { "en": "44 cm²" }, { "en": "154 cm²" }, { "en": "22 cm²" }, { "en": "49 cm²" } ], "answerIndex": 1,
      "solution": { "en": "Area = πr² = (22/7) × 7 × 7 = 22 × 7 = 154 cm²." } },
    { "id": "cbse-10-mathematics-sample-008", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "quadratic-equations", "difficulty": 2, "source": "Sample (CBSE 10)",
      "prompt": { "en": "The discriminant of the quadratic equation ax² + bx + c = 0 is:" },
      "choices": [ { "en": "b² − 4ac" }, { "en": "b² + 4ac" }, { "en": "2a + b" }, { "en": "√(b² − 4ac)" } ], "answerIndex": 0,
      "solution": { "en": "The discriminant is D = b² − 4ac. It decides the nature of the roots: real & distinct (D>0), equal (D=0), or no real roots (D<0)." } },
    { "id": "cbse-10-mathematics-sample-009", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "trigonometry", "difficulty": 1, "source": "Sample (CBSE 10)",
      "prompt": { "en": "The value of tan 45° is:" },
      "choices": [ { "en": "0" }, { "en": "1" }, { "en": "√3" }, { "en": "1/2" } ], "answerIndex": 1,
      "solution": { "en": "tan 45° = 1, because sin 45° = cos 45° = 1/√2, so their ratio is 1." } },
    { "id": "cbse-10-mathematics-sample-010", "type": "mcq", "exam": "cbse-10", "subject": "mathematics", "year": null, "topic": "polynomials", "difficulty": 2, "source": "Sample (CBSE 10)",
      "prompt": { "en": "The sum of the zeroes of the polynomial x² − 7x + 10 is:" },
      "choices": [ { "en": "7" }, { "en": "10" }, { "en": "−7" }, { "en": "3" } ], "answerIndex": 0,
      "solution": { "en": "For ax² + bx + c, the sum of zeroes = −b/a = −(−7)/1 = 7. (The zeroes are 2 and 5.)" } }
  ]
}
