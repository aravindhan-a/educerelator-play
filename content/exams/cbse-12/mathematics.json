      "difficulty": 3,
      "source": "Sample (CBSE Class 12)",
      "prompt": {
        "en": "If A and B are independent events with P(A) = 0.5 and P(B) = 0.4, then P(A ∪ B) equals:"
      },
      "choices": [
        {
          "en": "0.9"
        },
        {
          "en": "0.7"
        },
        {
          "en": "0.2"
        },
        {
          "en": "0.1"
        }
      ],
      "answerIndex": 1,
      "solution": {
        "en": "For independent events P(A ∩ B) = P(A)P(B) = 0.2, so P(A ∪ B) = P(A) + P(B) - P(A ∩ B) = 0.5 + 0.4 - 0.2 = 0.7."
      }
