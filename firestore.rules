rules_version = '2';

// Deploy: paste into Firebase console → Firestore → Rules, or
//   firebase deploy --only firestore:rules
//
// Premium and quota fields (premium, premiumPlan, premiumExpiry,
// lastPaymentId, aiUsage) are written ONLY by the backend Admin SDK,
// which bypasses these rules. Clients must never be able to write them —
// otherwise anyone could grant themselves premium from the browser console.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys()
             .hasOnly(['name', 'email', 'createdAt', 'lastActive', 'progress']);

      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['name', 'email', 'lastActive', 'progress']);

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
